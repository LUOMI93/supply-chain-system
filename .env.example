# Local development uses SQLite by default. For production SQLite, use an
# absolute path outside release directories, for example:
# DATABASE_URL="file:/var/lib/supply-chain/prod.db"
DATABASE_URL="file:./dev.db"

# Production database example. Replace with your real database connection.
# DATABASE_URL="postgresql://scuser:password@localhost:5432/supply_chain"

# NextAuth/Auth.js secret. Required in production. Generate your own value with:
# openssl rand -base64 32
AUTH_SECRET="replace-with-your-random-auth-secret"

# Required for production deployments behind a domain or server IP.
# Use your real public URL, for example:
# NEXTAUTH_URL="https://supply.example.com"
# NEXTAUTH_URL="http://your-server-ip:3000"
# AUTH_TRUST_HOST="true"

# Optional for local LAN testing with `pnpm dev`.
# Set this to the IP or host that other devices use to open the app.
# Multiple hosts can be separated by commas.
# LAN_HOST="192.168.1.10"

# Data encryption key. Use at least 32 bytes.
# openssl rand -base64 32
ENCRYPTION_KEY="replace-with-your-32-byte-encryption-key"

# Upload directory. In production this must be a persistent directory or volume,
# not a temporary build output directory.
# Example: UPLOAD_DIR="/var/lib/supply-chain/uploads"
UPLOAD_DIR="./public/uploads"

# Storage provider: local | oss. The current deployment path uses local storage.
STORAGE_PROVIDER="local"

# Optional backup settings used by `pnpm backup:sqlite`.
# BACKUP_DIR="./backups"
# BACKUP_KEEP="10"

# Production-only bootstrap account. Used by `pnpm db:init:prod`.
# Never use admin123/editor123/viewer123 in production.
# ADMIN_USERNAME="admin"
# ADMIN_DISPLAY_NAME="管理员"
# ADMIN_PASSWORD="replace-with-a-strong-initial-password"
