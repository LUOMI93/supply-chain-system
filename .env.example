# 开发环境使用 SQLite，生产环境使用 PostgreSQL
# 本地开发:
DATABASE_URL="file:./dev.db"

# 生产部署时改为:
# DATABASE_URL="postgresql://scuser:password@localhost:5432/supply_chain"

# NextAuth — 请用 `openssl rand -base64 32` 生成你自己的密钥
AUTH_SECRET="请替换为你生成的随机密钥"

# 加密密钥 — 必须 32 字节，请用 `openssl rand -base64 32` 生成
ENCRYPTION_KEY="请替换为你生成的32字节密钥"

# 上传目录
UPLOAD_DIR="./public/uploads"

# 存储提供商 (local | oss)
STORAGE_PROVIDER="local"
